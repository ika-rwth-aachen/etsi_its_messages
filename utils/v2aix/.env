# Environment configuration for v2aix_replay demo; currently this only supports bag-files from stationary recordings
# Absolute path to mounting-directory where bag files are located
BAG_DIR=

# Filepath to the bag file relative to BAG_DIR
BAG_PATH=

# Latitude / Longitude for RViz Aerial Map Display position for stationary recordings
# Uncomment the location based on the bag file used
# Aachen Heinrichsallee
#RVIZ_LAT=50.77658281569087
#RVIZ_LON=6.095012570578049
# Aachen Monheimsallee
#RVIZ_LAT=50.78072312867474
#RVIZ_LON=6.090690178012994
# Aachen Ponttor
#RVIZ_LAT=50.78167430986725
#RVIZ_LON=6.077795543661656
# Aachen Theaterstraße
#RVIZ_LAT=50.77075341297612
#RVIZ_LON=6.091811857058646
# A44 Jackerath
#RVIZ_LAT=51.03356003246729
#RVIZ_LON=6.476452912080067
